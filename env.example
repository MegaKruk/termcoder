# Copy this file to .env in your workspace to load secrets automatically.
# termcoder reads .env at startup and sets any variable not already exported,
# so you do not have to re-run export in every new terminal. Values already
# set in your shell win, and this file should be git-ignored.

OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Web search via a self-hosted SearXNG instance (optional).
# SEARXNG_API_BASE=http://localhost:8080
